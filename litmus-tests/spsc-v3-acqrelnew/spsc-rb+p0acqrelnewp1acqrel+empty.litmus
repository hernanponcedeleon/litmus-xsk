C spsc-rb+p0acqrelnewp1acqrel+empty

// Simple one entry ring:
// prod_head prod cons       allowed action       prod_head prod cons
//    	   0    0    0  =>     stage prod      =>   	  1    0	0
//         0    0	 1  =>       cons          =>   	  0    0	0
//         0    1    0  =>     impossible      =>   	  -    -	-
//         0    1    1  =>     commit prod     =>   	  0	   0	1
//    	   1    0    0  =>     commit prod     =>   	  1    1	0
//         1    0	 1  =>     impossible      =>   	  -    -	-
//         1    1    0  =>       cons          =>   	  1    1	1
//         1    1    1  =>     stage prod      =>   	  0	   1	1

// New acqrel in kernel and the old acqrel algorithm in userspace.
// We start at prod_head==0, prod==0, cons==0, data0==0.
// Producer writes 1 to data0, consumer should read 1.
// Can we enter state prod==1, cons==1, but consumer observed
// the incorrect value of 0?

{}

P0(int *prod_head, int *prod, int *cons, int *data0)
{
	int capacity = 1;
	int r_cmp;
	int ph;
	int c;

	ph = READ_ONCE(*prod_head);

	c = READ_ONCE(*cons);
	if ((ph - c) < capacity) {
		r_cmp = cmpxchg(prod_head, ph, ph ^ 1);
		if (r_cmp == ph) {
			WRITE_ONCE(*data0, 1);
		
			if (READ_ONCE(*prod) == ph) {
				smp_store_release(prod, ph ^ 1);
			}
		}
	}
}

P1(int *prod, int *cons, int *data0) {
    int d = -1;
    int c;

    c = READ_ONCE(*cons);
    if (smp_load_acquire(prod) != c) {
        d = READ_ONCE(*data0);
        smp_store_release(cons, c ^ 1);
    }
}

exists( 
    (1:d=0 /\ prod_head=1 /\ prod=1 /\ cons=1)
);

